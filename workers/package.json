{
  "name": "@sfl-digging-hub/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "deploy": "wrangler deploy --env production",
    "db:migrate:local": "wrangler d1 migrations apply sfl-digging-hub --local",
    "db:migrate": "wrangler d1 migrations apply sfl-digging-hub --remote",
    "cf:migrate": "wrangler d1 migrations apply sfl-digging-hub --remote --env production",
    "cf:migrate:beta": "wrangler d1 migrations apply sfl-digging-hub-beta --remote --env beta"
  },
  "dependencies": {
    "@sfl-digging-hub/shared": "*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250525.0",
    "typescript": "^5.8.3",
    "wrangler": "^4.14.0"
  }
}
